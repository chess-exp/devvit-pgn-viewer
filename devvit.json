{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "pgn-viewer",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "viewer.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "permissions": {
    "reddit": true,
    "redis": true
  },
  "menu": {
    "items": [
      {
        "label": "Create PGN Viewer",
        "description": "Create an interactive chess PGN post",
        "location": "subreddit",
        "forUserType": "user",
        "endpoint": "/internal/menu/create-pgn-viewer"
      }
    ]
  },
  "forms": {
    "createPgnViewer": "/internal/form/create-pgn-viewer"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  }
}
